local roundAutoPlayConn=nil
local startAutoPlayLeft
local startAutoPlayRight
local function startRoundAutoPlay()
    if roundAutoPlayConn then roundAutoPlayConn:Disconnect() roundAutoPlayConn=nil end
    local function watchGui(gui)
        if not gui:IsA("ScreenGui") then return end
        local function scanLabels(obj)
            for _,v in ipairs(obj:GetDescendants()) do
                if v:IsA("TextLabel") or v:IsA("TextButton") then
                    v:GetPropertyChangedSignal("Text"):Connect(function()
                        if not Features.RoundAutoPlay then return end
                        if v.Text=="5" or v.Text=="5." then
                            task.delay(5.05,function()
                                if not Features.RoundAutoPlay then return end
                                local side=_G.BlexGetTPSide and _G.BlexGetTPSide() or "left"
                                if side=="left" then
                                    Features.AutoPlayLeft=true
                                    if ToggleControls.AutoPlayLeft then ToggleControls.AutoPlayLeft.setVisual(true) end
                                    startAutoPlayLeft(1)
                                else
                                    Features.AutoPlayRight=true
                                    if ToggleControls.AutoPlayRight then ToggleControls.AutoPlayRight.setVisual(true) end
                                    startAutoPlayRight(1)
                                end
                            end)
                        end
                    end)
                end
            end
        end
        scanLabels(gui)
        gui.DescendantAdded:Connect(function(d)
            if d:IsA("TextLabel") or d:IsA("TextButton") then
                d:GetPropertyChangedSignal("Text"):Connect(function()
                    if not Features.RoundAutoPlay then return end
                    if d.Text=="5" or d.Text=="5." then
                        task.delay(5.05,function()
                            if not Features.RoundAutoPlay then return end
                            local side=_G.BlexGetTPSide and _G.BlexGetTPSide() or "left"
                            if side=="left" then
                                Features.AutoPlayLeft=true
                                if ToggleControls.AutoPlayLeft then ToggleControls.AutoPlayLeft.setVisual(true) end
                                startAutoPlayLeft(1)
                            else
                                Features.AutoPlayRight=true
                                if ToggleControls.AutoPlayRight then ToggleControls.AutoPlayRight.setVisual(true) end
                                startAutoPlayRight(1)
                            end
                        end)
                    end
                end)
            end
        end)
    end
    for _,gui in ipairs(PlayerGui:GetChildren()) do watchGui(gui) end
    roundAutoPlayConn=PlayerGui.ChildAdded:Connect(function(child) watchGui(child) end)
end
