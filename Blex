    s.Thickness=th s.Color=col s.Transparency=tr
    s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
end
local function pulse(obj,prop,v1,v2,t)
    task.spawn(function()
        while obj and obj.Parent do
            TweenService:Create(obj,TweenInfo.new(t or 0.9),{[prop]=v2}):Play() task.wait(t or 0.9)
            TweenService:Create(obj,TweenInfo.new(t or 0.9),{[prop]=v1}):Play() task.wait(t or 0.9)
        end
    end)
end
local function toV3(v)
    if typeof(v)=="Vector3" then return v end
    return Vector3.new(v.X or 0,v.Y or 0,v.Z or 0)
end
local function serWPs(t)
    local o={} for _,v in ipairs(t) do local v3=toV3(v) table.insert(o,{X=v3.X,Y=v3.Y,Z=v3.Z}) end return o
end
