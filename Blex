local BatAln={}
local function startBA()
    local ch=Player.Character or Player.CharacterAdded:Wait()
    local hrp=ch:WaitForChild("HumanoidRootPart")
    BatAln.Att=Instance.new("Attachment",hrp)
    BatAln.Aln=Instance.new("AlignOrientation",hrp)
    BatAln.Aln.Attachment0=BatAln.Att
    BatAln.Aln.Mode=Enum.OrientationAlignmentMode.OneAttachment
    BatAln.Aln.RigidityEnabled=true
    BatAln.Aln.Enabled=false
    Connections.bat=RunService.Heartbeat:Connect(function()
        if not Features.BatAimbot then return end
        local c=Player.Character if not c then return end
        local h=c:FindFirstChild("HumanoidRootPart") if not h then return end
        local hum=c:FindFirstChildOfClass("Humanoid") if not hum then return end
        local np=getNP()
        if np and np.Character and np.Character:FindFirstChild("HumanoidRootPart") then
            local tpos=np.Character.HumanoidRootPart.Position
            local dir=tpos-h.Position
            local dist=dir.Magnitude
            hum.AutoRotate=false
            BatAln.Aln.Enabled=true
            BatAln.Aln.CFrame=CFrame.lookAt(h.Position,Vector3.new(tpos.X,h.Position.Y,tpos.Z))
            if dist>1.5 then
                h.AssemblyLinearVelocity=Vector3.new(dir.Unit.X*55,dir.Unit.Y*55,dir.Unit.Z*55)
            else
                h.AssemblyLinearVelocity=Vector3.new(dir.Unit.X*2,dir.Unit.Y*2,dir.Unit.Z*2)
            end
        else
            BatAln.Aln.Enabled=false
            hum.AutoRotate=true
            h.AssemblyLinearVelocity=Vector3.zero
        end
    end)
    task.spawn(function()
        while Features.BatAimbot do
            local c=Player.Character
            if c then
                local hum=c:FindFirstChildOfClass("Humanoid")
                if hum then
                    local bat=c:FindFirstChild("Bat") or Player.Backpack:FindFirstChild("Bat")
                    if bat then
                        if bat.Parent==Player.Backpack then hum:EquipTool(bat) task.wait(0.1) end
                        local eb=c:FindFirstChild("Bat") if eb then eb:Activate() end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end
local function stopBA()
    if Connections.bat then Connections.bat:Disconnect() Connections.bat=nil end
    if BatAln.Aln then BatAln.Aln:Destroy() BatAln.Aln=nil end
    if BatAln.Att then BatAln.Att:Destroy() BatAln.Att=nil end
    local ch=Player.Character
    if ch then
        local hum=ch:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate=true end
        local h=ch:FindFirstChild("HumanoidRootPart")
        if h then h.AssemblyLinearVelocity=Vector3.zero end
    end
    BatAln={}
end
