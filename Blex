local isStealing=false local StealData={}
local function isMyPlot(pn)
    local pl=workspace:FindFirstChild("Plots") if not pl then return false end
    local p=pl:FindFirstChild(pn) if not p then return false end
    local sg=p:FindFirstChild("PlotSign")
    if sg then local yb=sg:FindFirstChild("YourBase") if yb and yb:IsA("BillboardGui") then return yb.Enabled end end
    return false
end
local function findPrompt()
    local mh=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") if not mh then return nil end
    local pl=workspace:FindFirstChild("Plots") if not pl then return nil end
    local np,nd,nn=nil,math.huge,nil
    for _,plot in ipairs(pl:GetChildren()) do
        if isMyPlot(plot.Name) then continue end
        local pods=plot:FindFirstChild("AnimalPodiums") if not pods then continue end
        for _,pod in ipairs(pods:GetChildren()) do
            pcall(function()
                local base=pod:FindFirstChild("Base")
                local sp=base and base:FindFirstChild("Spawn")
                if sp then
                    local dist=(sp.Position-mh.Position).Magnitude
                    if dist<nd and dist<=ASV.STEAL_RADIUS then
                        local att=sp:FindFirstChild("PromptAttachment")
                        if att then
                            for _,ch in ipairs(att:GetChildren()) do
                                if ch:IsA("ProximityPrompt") then np,nd,nn=ch,dist,pod.Name break end
                            end
                        end
                    end
                end
            end)
        end
    end
    return np,nd,nn
end
local function execSteal(prompt,name)
    if isStealing then return end
    if not StealData[prompt] then
        StealData[prompt]={hold={},trigger={},ready=true}
        pcall(function()
            if getconnections then
                for _,c in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do if c.Function then table.insert(StealData[prompt].hold,c.Function) end end
                for _,c in ipairs(getconnections(prompt.Triggered)) do if c.Function then table.insert(StealData[prompt].trigger,c.Function) end end
            end
        end)
    end
    local data=StealData[prompt] if not data.ready then return end
    data.ready=false isStealing=true stealT0=tick()
    if PBLabel then PBLabel.Text=name or "stealing..." end
    if progressConn then progressConn:Disconnect() end
    progressConn=RunService.Heartbeat:Connect(function()
        if not isStealing then progressConn:Disconnect() return end
        local prog=math.clamp((tick()-stealT0)/ASV.STEAL_DURATION,0,1)
        if PBFill then PBFill.Size=UDim2.new(prog,0,1,0) end
        if PBPct  then PBPct.Text=wmarkReveal(math.floor(prog*100)) end
    end)
    task.spawn(function()
        for _,f in ipairs(data.hold) do task.spawn(f) end
        task.wait(ASV.STEAL_DURATION)
        for _,f in ipairs(data.trigger) do task.spawn(f) end
        if progressConn then progressConn:Disconnect() progressConn=nil end
        resetPB() data.ready=true isStealing=false
    end)
end
