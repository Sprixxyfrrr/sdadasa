local function startHitDetector()
    if hitDetectConn then hitDetectConn:Disconnect() hitDetectConn=nil end
    hitDetectConn=RunService.Heartbeat:Connect(function()
        if not Features.AutoPlayAfterTP then return end
        if hitTPCooldown then return end
        if not isHit() then return end
        hitTPCooldown=true
        local wasLeft=lastAutoPlaySide=="left"
        stopAutoPlayLeft()
        stopAutoPlayRight()
        task.spawn(function()
            local c=Player.Character
            if c then
                local hrp=c:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if wasLeft then
                        hrp.CFrame=CFrame.new(TP_L1) task.wait(TP_DELAY) hrp.CFrame=CFrame.new(TP_L2)
                    else
                        hrp.CFrame=CFrame.new(TP_R1) task.wait(TP_DELAY) hrp.CFrame=CFrame.new(TP_R2)
                    end
                end
            end
            if wasLeft then
                Features.AutoPlayLeft=true
                if ToggleControls.AutoPlayLeft then ToggleControls.AutoPlayLeft.setVisual(true) end
                startAutoPlayLeft(2)
            else
                Features.AutoPlayRight=true
                if ToggleControls.AutoPlayRight then ToggleControls.AutoPlayRight.setVisual(true) end
                startAutoPlayRight(2)
            end
            task.wait(1)
            hitTPCooldown=false
        end)
    end)
end
startAutoPlayLeft=function(startWP)
    lastAutoPlaySide="left"
    stopAutoPlayLeft() aplWP=startWP or 1
    aplConn=RunService.Heartbeat:Connect(function()
        if not Features.AutoPlayLeft then stopAutoPlayLeft() return end
        local c=Player.Character if not c then return end
        local h=c:FindFirstChild("HumanoidRootPart") if not h then return end
        local wp=leftWaypoints[aplWP] if not wp then return end
        local wpX=toV3(wp).X local wpZ=toV3(wp).Z
        local cxz=Vector2.new(h.Position.X,h.Position.Z)
        local txz=Vector2.new(wpX,wpZ)
        if (txz-cxz).Magnitude>3 then
            local d=(txz-cxz).Unit
            local spd=aplWP>=3 and Values.StealingSpeedValue or Values.BoostSpeed
            local dyTarget=toV3(wp).Y-h.Position.Y
            local vy=math.clamp(dyTarget*5,-60,60)
            h.AssemblyLinearVelocity=Vector3.new(d.X*spd,vy,d.Y*spd)
