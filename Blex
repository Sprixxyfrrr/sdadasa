local function stealAtPos()
    local c=Player.Character if not c then return end
    local h=c:FindFirstChild("HumanoidRootPart") if not h then return end
    local plots=workspace:FindFirstChild("Plots") if not plots then return end
    for _,pl in ipairs(plots:GetChildren()) do
        local po=pl:FindFirstChild("AnimalPodiums") if not po then continue end
        for _,pod in ipairs(po:GetChildren()) do
            if pod:IsA("Model") and pod:FindFirstChild("Base") then
                local s=pod.Base:FindFirstChild("Spawn")
                if s and (s.Position-h.Position).Magnitude<12 then
                    local a=s:FindFirstChild("PromptAttachment")
                    if a then
                        local p=a:FindFirstChildOfClass("ProximityPrompt")
                        if p then
                            pcall(function()
                                if getconnections then
                                    for _,c2 in ipairs(getconnections(p.PromptButtonHoldBegan)) do task.spawn(c2.Function) end
                                    task.wait(0.1)
                                    for _,c2 in ipairs(getconnections(p.Triggered)) do task.spawn(c2.Function) end
                                end
                            end) return
                        end
                    end
                end
            end
        end
    end
end
